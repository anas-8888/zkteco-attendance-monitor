{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "nexa-attendance-monitor",
    "version": "1.0.0",
    "description": "Nexa Attendance Monitor desktop app",
    "author": "OpenAI Codex",
    "private": true,
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "electron:prepare-app-icon": "node scripts/electron/generate-app-icon.mjs",
        "electron:prepare-installer-assets": "npm run electron:prepare-app-icon && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/electron/generate-installer-assets.ps1",
        "electron:prepare-runtime": "node scripts/electron/prepare-runtime.mjs",
        "electron:prepare-php": "node scripts/electron/prepare-php.mjs",
        "electron:prepare": "npm run build && npm run electron:prepare-installer-assets && npm run electron:prepare-runtime && npm run electron:prepare-php",
        "electron:dev": "npm run electron:prepare && electron .",
        "electron:pack": "npm run electron:prepare && electron-builder --win dir",
        "electron:dist": "npm run electron:prepare && electron-builder --win nsis"
    },
    "build": {
        "appId": "com.nexa.attendance.monitor",
        "productName": "Nexa Attendance Monitor",
        "afterPack": "scripts/electron/after-pack.mjs",
        "directories": {
            "output": "dist-electron"
        },
        "asar": true,
        "files": [
            "electron/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": ".electron/laravel-app",
                "to": "laravel-app"
            },
            {
                "from": ".electron/php/windows",
                "to": "php/windows"
            },
            {
                "from": "build/icon.ico",
                "to": "assets/icon.ico"
            }
        ],
        "win": {
            "signAndEditExecutable": false,
            "icon": "build/icon.ico",
            "target": [
                "nsis"
            ],
            "artifactName": "Nexa-Attendance-Monitor-Setup-${version}.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "selectPerMachineByDefault": false,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "runAfterFinish": true,
            "shortcutName": "Nexa Attendance Monitor",
            "uninstallDisplayName": "Nexa Attendance Monitor",
            "installerIcon": "build/icon.ico",
            "installerHeader": "build/installerHeader.bmp",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico",
            "installerSidebar": "build/installerSidebar.bmp",
            "uninstallerSidebar": "build/uninstallerSidebar.bmp",
            "deleteAppDataOnUninstall": false
        }
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "electron": "^28.3.3",
        "electron-builder": "^25.1.8",
        "laravel-vite-plugin": "^2.0.0",
        "png-to-ico": "^3.0.2",
        "rcedit": "^5.0.2",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
